# LLM 配置
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-max
LLM_TEMPERATURE=0.7
LLM_EMBED_MODEL=text-embedding-v3

# 模式切换: demo（内存存储）| production（Milvus + ES）
MODE=production

# Milvus（production 模式）
MILVUS_HOST=your-host
MILVUS_PORT=19530
MILVUS_USER=root
MILVUS_PASSWORD=your-password
MILVUS_COLLECTION=m_indexflow_kb

# Elasticsearch（production 模式）
ES_URL=http://elastic:your-password@your-host:9200
ES_INDEX=m_indexflow_kb
